# --- Required ---------------------------------------------------------------
# Surfaced via modelProviderData on the Claude deployment.
# `industry` MUST be lowercase to match the Foundry portal dropdown.
CLAUDE_ORGANIZATION_NAME=Your Organization
CLAUDE_COUNTRY_CODE=US
CLAUDE_INDUSTRY=technology

# --- Optional ---------------------------------------------------------------
AZURE_LOCATION=eastus2
AZURE_BASE_NAME=claude

# Per-family deployments (preferred). Set any combination; empty = skip.
# CLAUDE_HAIKU_MODEL=claude-haiku-4-5
# CLAUDE_SONNET_MODEL=claude-sonnet-4-6
# CLAUDE_OPUS_MODEL=claude-opus-4-6
# CLAUDE_HAIKU_CAPACITY=25
# CLAUDE_SONNET_CAPACITY=25
# CLAUDE_OPUS_CAPACITY=25

# Legacy single-deployment fallback (only used when all CLAUDE_*_MODEL above are empty).
CLAUDE_MODEL_NAME=claude-sonnet-4-6
CLAUDE_MODEL_VERSION=1
CLAUDE_MODEL_CAPACITY=25

# Grant `Cognitive Services User` (least-privilege inference role, GUID
# a97b65f3-24c7-4388-baec-2e87135dc908) to AZURE_PRINCIPAL_ID on the Foundry
# account during `azd up`. Requires Microsoft.Authorization/roleAssignments/write
# on the deployer.
# ASSIGN_RBAC=true

# Let the postprovision hook run the official Claude Code installer if `claude` isn't on PATH.
# CLAUDE_CODE_AUTO_INSTALL=true

# Populated automatically by `azd up` after provisioning. You can also set
# these manually if running the sample standalone.
# CLAUDE_BASE_URL=https://<resource>.services.ai.azure.com/anthropic
# CLAUDE_DEPLOYMENT_NAME=claude-sonnet-4-6-abc123
